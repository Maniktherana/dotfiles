// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "ui_font_family": ".ZedSans",
  "icon_theme": "Material Icon Theme",
  "theme": "Vesper",
  "buffer_font_size": 13,
  "ui_font_size": 13.5,
  "tab_size": 4,
  "buffer_font_family": ".ZedMono",
  "format_on_save": "on",
  "project_panel": {
    "dock": "left",
    "starts_open": true,
    "entry_spacing": "standard",
    "default_width": 300,
    "folder_icons": false,
    "indent_size": 12
  },
  "outline_panel": {
    "dock": "right",
    "button": false
  },
  "notification_panel": {
    "button": false
  },
  "agent": {
    "default_model": {
      "provider": "codex",
      "model": "gpt-4o"
    },
    "button": true
  },
  "terminal": {
    "button": true,
    "dock": "bottom"
  },
  "collaboration_panel": {
    "button": false
  },
  "minimap": {
    "show": "always",
    "thumb": "always",
    "thumb_border": "left_open",
    "current_line_highlight": "all"
  },
  "scrollbar": {
    "git_diff": true
  },
  "git": {
    "hunk_style": "staged_hollow",
    "inline_blame": {
      "enabled": true,
      "show_commit_summary": true,
      "delay_ms": 250,
      "min_column": 100
    },
    "git_gutter": "tracked_files"
  },
  "status_bar": {
    "active_language_button": true,
    "cursor_position_button": true,
    "line_endings_button": true
  },
  "experimental.theme_overrides": {
    "background.appearance": "blurred",
    "background": "#000000B3",
    "status_bar.background": "#000000",
    "title_bar.background": "#00000099",
    "elevated_surface.background": "#262626",
    "surface.background": "#00000085",
    "border": "#ffffff10",
    "hint.background": "#0000001c",
    "editor.background": "#0000001c",
    "editor.gutter.background": "#0000001c",
    "editor.line_number": "#a9b1d6F2",
    "editor.active_line_number": "#0db9d7",
    "tab_bar.background": "#00000000",
    "terminal.background": "#00000000",
    "terminal.ansi.white": "#cfd7fa",
    "terminal.foreground": "#cfd7fa",
    "toolbar.background": "#000000",
    "tab.active_background": "#00eaff30",
    "tab.inactive_background": "#000000",
    "panel.background": "#00000000",
    "scrollbar.track.border": "#00000000",
    "scrollbar.track.background": "#00000000",
    "scrollbar.thumb.border": "#00000000",
    "scrollbar.thumb.background": "#ffffff1c",
    "ghost_element.hover": "#ffffff40",
    "ghost_element.background": "#00000000",
    "ghost_element.active": "#ffffff40",
    "ghost_element.selected": "#ffffff60"
  },
  "theme_overrides": {
    "Tokyo Night": {
      "editor.active_line.background": "#0db9d74c",
      "element.hover": "#ffffff30",
      "editor.document_highlight.bracket_background": "#cfd7fa4d"
    }
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false
  },
  "features": {
    "edit_prediction_provider": "none"
  },
  "hard_tabs": true
}
