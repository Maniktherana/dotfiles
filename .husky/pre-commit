#!/bin/sh
set -e

# sync dotfiles from ~ into repo
echo "syncing dotfiles..."
bun run sync.ts
git add -A

# format + lint
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED_FILES" ]; then
  echo "No staged files to format"
  exit 0
fi

bun run format
bun run lint

echo "$STAGED_FILES" | while IFS= read -r file; do
  if [ -f "$file" ]; then
    git add "$file"
  fi
done
